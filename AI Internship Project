class TextPreprocessor:
    """
    NLP Preprocessing Pipeline:
      1. Lowercase
      2. Remove punctuation and special characters
      3. Tokenize (NLTK word_tokenize)
      4. Remove stopwords
      5. Return cleaned token list
    """

    def preprocess(self, text: str) -> list[str]:
        text = text.lower()
        text = re.sub(r'[^a-z0-9\s]', ' ', text)
        tokens = word_tokenize(text)
        tokens = [t for t in tokens if t not in STOP_WORDS and len(t) > 1]
        return tokens


class TFIDFEngine:
    """
    Builds TF-IDF vectors for a FAQ corpus.
    Computes cosine similarity between a query and each FAQ.
    """

    def __init__(self, preprocessor: TextPreprocessor):
        self.preprocessor = preprocessor
        self.corpus_vectors = []
        self.faqs = []

    def fit(self, faqs: list[dict]):
        self.faqs = faqs
        self.corpus_vectors = []

        tokenized = []
        for faq in faqs:
            combined = faq['question'] + ' ' + ' '.join(faq.get('tags', []))
            tokenized.append(self.preprocessor.preprocess(combined))

        # Build document frequency
        df = defaultdict(int)
        for tokens in tokenized:
            for term in set(tokens):
                df[term] += 1

        N = len(faqs)

        for tokens in tokenized:
            tf = defaultdict(int)
            for t in tokens:
                tf[t] += 1
            vec = {}
            for t, count in tf.items():
                tfidf = (count / len(tokens)) * math.log((N + 1) / (df[t] + 1))
                vec[t] = tfidf
            self.corpus_vectors.append(vec)

    def _query_vec(self, query: str) -> dict:
        tokens = self.preprocessor.preprocess(query)
        tf = defaultdict(int)
        for t in tokens:
            tf[t] += 1
        vec = {}
        for t, count in tf.items():
            vec[t] = count / len(tokens) if tokens else 0
        return vec

    def _cosine_sim(self, vec_a: dict, vec_b: dict) -> float:
        all_keys = set(vec_a) | set(vec_b)
        dot = sum(vec_a.get(k, 0) * vec_b.get(k, 0) for k in all_keys)
        norm_a = math.sqrt(sum(v ** 2 for v in vec_a.values()))
        norm_b = math.sqrt(sum(v ** 2 for v in vec_b.values()))
        return dot / (norm_a * norm_b) if norm_a and norm_b else 0.0

    def find_best_match(self, query: str) -> tuple[dict, float, list]:
        q_vec = self._query_vec(query)
        scores = [self._cosine_sim(q_vec, cv) for cv in self.corpus_vectors]

        sorted_idx = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)
        best_idx = sorted_idx[0]
        best_score = scores[best_idx]

        # Top 3 runner-ups as suggestions
        suggestions = [
            self.faqs[i]['question']
            for i in sorted_idx[1:4]
            if scores[i] > 0.05
        ]

        return self.faqs[best_idx], round(best_score, 4), suggestions


class NehalChatbot:
    """
    Main chatbot class.
    Supports multiple FAQ topics and uses TF-IDF cosine similarity matching.
    """

    LOW_CONFIDENCE_THRESHOLD = 0.05

    def __init__(self):
        self.preprocessor = TextPreprocessor()
        self.engines: dict[str, TFIDFEngine] = {}
        self.current_topic = "ecommerce"
        self._load_all_topics()

    def _load_all_topics(self):
        for topic, faqs in FAQ_DATABASE.items():
            engine = TFIDFEngine(self.preprocessor)
            engine.fit(faqs)
            self.engines[topic] = engine
        print(f"[Nehal] Loaded {len(FAQ_DATABASE)} topics: {list(FAQ_DATABASE.keys())}")

    def set_topic(self, topic: str) -> bool:
        if topic in self.engines:
            self.current_topic = topic
            return True
        return False

    def respond(self, user_input: str) -> dict:
        engine = self.engines[self.current_topic]
        faq, score, suggestions = engine.find_best_match(user_input)

        if score < self.LOW_CONFIDENCE_THRESHOLD:
            return {
                "matched_question": None,
                "answer": "I couldn't find a close match. Try rephrasing your question.",
                "confidence": score,
                "confidence_pct": 0,
                "suggestions": [f['question'] for f in FAQ_DATABASE[self.current_topic][:3]],
                "topic": self.current_topic
            }

        return {
            "matched_question": faq['question'],
            "answer": faq['answer'],
            "confidence": score,
            "confidence_pct": round(score * 100),
            "suggestions": suggestions,
            "topic": self.current_topic
        }


