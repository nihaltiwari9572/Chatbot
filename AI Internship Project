    print("  Topics:", ', '.join(FAQ_DATABASE.keys()))
    print("="*55 + "\n")

    while True:
        try:
            user_input = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n[Nehal] Goodbye!")
            break

        if not user_input:
            continue

        if user_input.lower() == 'quit':
            print("[Nehal] Goodbye!")
            break

        if user_input.lower().startswith("topic:"):
            topic = user_input.split(":", 1)[1].strip()
            if bot.set_topic(topic):
                print(f"[Nehal] Switched to topic: {topic}\n")
            else:
                print(f"[Nehal] Unknown topic '{topic}'. Available: {list(FAQ_DATABASE.keys())}\n")
            continue

        result = bot.respond(user_input)

        print(f"\n[Nehal] ", end="")
        if result['matched_question']:
            print(f"(FAQ: {result['matched_question']})")
        print(f"  {result['answer']}")
        print(f"  Confidence: {result['confidence_pct']}%")
        if result['suggestions']:
            print(f"  Related: {' | '.join(result['suggestions'][:2])}")
        print()


